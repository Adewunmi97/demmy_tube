<%= form_with url: posts_path, method: :get, local: true, data: {searchDelayValue: 300, controller: "search", turbo_frame: "posts"}, class: "w-full" do |form| %>
    <%= form.text_field :query, value: params[:query], placeholder: "Search post...", autocomplete: "off",
    data: { action: "input->search#submit" },
    class: "w-full rounded-full border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-blue-focus:outline-none transition text-sm placeholder-gray-500" %>
    <svg class= "absolute right-3 top-2.5 h-5 w-5 text-gray-400 pointer-events-noxmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z" />
    </svg>
<% end %>