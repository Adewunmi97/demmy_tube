<% if current_user %>
  <div class="w-xl mx-auto mt-12 p-8 bg-white rounded-lg shadow-lg space-y-8">
    <div class="text-xl font-extrabold text-gray-900">
      Hi 👋 <%= current_user.name || "User" %>
    </div>

    <div class="flex space-x-10">
      <!-- Profile Image -->
      <div class="flex items-center justify-center flex-shrink-0">
        <%= image_tag(current_user.avatar_url.presence || "user.png", alt: "Profile picture", class: "w-28 h-28 rounded-full") %>
      </div>

      <!-- Info Section -->
      <div class="flex flex-col justify-center flex-grow space-y-6">

        <!-- Email -->
        <div class="flex justify-between items-center text-lg">
          <span class="font-semibold text-gray-600">Email:</span>
          <span class="text-gray-900"><%= current_user.email %></span>
        </div>

        <!-- Provider -->
        <div class="flex justify-between items-center text-lg">
          <span class="font-semibold text-gray-600">Signed in with:</span>
          <span class="text-gray-900"><%= current_user.provider.present? ? current_user.provider.capitalize : "Email" %></span>
        </div>

        <!-- Joined On -->
        <div class="flex justify-between items-center text-lg">
          <span class="font-semibold text-gray-600">Joined on:</span>
          <span class="text-gray-900"><%= current_user.created_at.strftime("%d %b %Y") %></span>
        </div>

      </div>
    </div>

    <!-- Sign Out Button -->
    <div class="flex justify-end">
      <%= button_to "Sign out", destroy_user_session_path, method: :delete,
            data: { turbo: false, confirm: "Are you sure you want to sign out?" },
            class: "px-6 py-2 bg-red-600 text-white font-semibold rounded-lg shadow-md hover:bg-red-700 focus:outline-none focus:ring" %>
    </div>
  </div>
<% end %>
