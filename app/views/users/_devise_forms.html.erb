<div class="space-y-6">

  <!-- Headline and description -->
  <div class="text-center">
    <h2 class="text-2xl font-semibold mb-2 text-gray-900">
      Sign in to access PRO lessons
    </h2>
    <p class="text-gray-600 text-sm max-w-sm mx-auto">
      Access private repos, leave comments, create watch lists.
    </p>
  </div>

  <!-- OAuth Buttons -->
  <div class="flex flex-col gap-4">

    <%= button_to user_github_omniauth_authorize_path, method: :post, data: { turbo: false },
      class: "w-full flex items-center justify-center gap-3 border border-gray-300 rounded-md py-3 hover:bg-gray-100 transition text-sm font-medium" do %>
      <!-- GitHub Icon SVG -->
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.166 6.84 9.49.5.09.68-.22.68-.49v-1.71c-2.78.61-3.37-1.34-3.37-1.34-.46-1.17-1.12-1.48-1.12-1.48-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.36 1.08 2.94.83.09-.65.35-1.08.63-1.33-2.22-.25-4.55-1.11-4.55-4.95 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.28.1-2.66 0 0 .84-.27 2.75 1.02A9.6 9.6 0 0 1 12 6.8c.85.004 1.71.115 2.51.338 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.41.1 2.66.64.7 1.03 1.6 1.03 2.69 0 3.85-2.34 4.7-4.57 4.95.36.31.69.92.69 1.85v2.74c0 .27.18.58.69.49A10 10 0 0 0 22 12c0-5.52-4.48-10-10-10z" />
      </svg>
      Sign up with GitHub
    <% end %>

    <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false },
      class: "w-full flex items-center justify-center gap-3 border border-gray-300 rounded-md py-3 hover:bg-gray-100 transition text-sm font-medium" do %>
      <!-- Google Icon SVG -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-6 h-6" style="display: block;">
        <path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.9 2.7 30.4 0 24 0 14.6 0 6.5 5.5 2.5 13.4l7.9 6.1C12.3 13.6 17.7 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.1 24.6c0-1.6-.1-3.1-.4-4.6H24v9.1h12.5c-.5 2.7-2 5-4.1 6.6l6.4 5 8.7-6.9c2.5-4 3.6-8.2 3.6-13.2z"/>
        <path fill="#FBBC05" d="M10.4 28.8c-.5-1.6-.8-3.2-.8-4.8s.3-3.3.8-4.8l-7.9-6.1C.9 15.5 0 19.1 0 24s.9 8.5 2.5 12.1l7.9-6.1z"/>
        <path fill="#34A853" d="M24 48c6.5 0 11.9-2.1 15.8-5.9l-7.7-6c-2.1 1.4-4.7 2.2-8.1 2.2-6.3 0-11.7-4.1-13.6-9.6l-7.9 6.1C6.5 42.5 14.6 48 24 48z"/>
        <path fill="none" d="M0 0h48v48H0z"/>
      </svg>
      Sign up with Google
    <% end %>
  </div>

  <!-- Info Note -->
  <p class="text-xs text-gray-500 mt-3 max-w-xs mx-auto text-center">
    We collect your email address, name and username to create your account. 
    We do not share your email address with anyone else.
  </p>
</div>
